# ==========================================
# AI Model Selection (env-based, no ~/.claude dependency)
# ==========================================
use-claude() {
  local quiet=${1:-}
  unset ANTHROPIC_AUTH_TOKEN
  unset ANTHROPIC_API_KEY
  unset ANTHROPIC_BASE_URL
  unset ANTHROPIC_MODEL
  unset ANTHROPIC_DEFAULT_OPUS_MODEL
  unset ANTHROPIC_DEFAULT_SONNET_MODEL
  unset ANTHROPIC_DEFAULT_HAIKU_MODEL
  if [[ "$quiet" != "--quiet" ]]; then
    echo "✓ Switched to Claude subscription (Anthropic direct)"
    echo "  Use: claude --model opus/sonnet/haiku"
  fi
}

use-alibaba() {
  local model=${1:-qwen3.6-plus}
  export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}"
  unset ANTHROPIC_AUTH_TOKEN
  export ANTHROPIC_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/apps/anthropic"
  export ANTHROPIC_MODEL="$model"
  echo "✓ Switched to Alibaba Coding Plan → $model"
  echo "  Pro plan: 90K requests/month"
  echo "  Other models: use-alibaba qwen3.6-plus, use-alibaba qwen3.5-plus, use-alibaba glm-5, use-alibaba kimi-2.5"
}

ai-status() {
  if [[ -n "$ANTHROPIC_BASE_URL" ]]; then
    echo "Current backend: Alibaba Coding Plan (Pro)"
    echo "  Default model: $ANTHROPIC_MODEL"
  else
    echo "Current backend: Claude subscription (Anthropic direct)"
    echo "  Models: opus, sonnet, haiku"
  fi
}

# Default to Claude subscription on new shell
use-claude --quiet


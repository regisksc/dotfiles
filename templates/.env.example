# ============================================================
# dotfiles — .env.example
# ============================================================
# Copy this file to .env.local (gitignored) and fill in real values.
# .env.local is sourced at template-render time (./install.sh install).
# NEVER commit .env.local or any file with real secrets.
#
# Usage:
#   cp templates/.env.example .env.local
#   $EDITOR .env.local
#   ./install.sh install
# ============================================================

# ------------------------------------------------------------
# SHELL / ZSHRC
# ------------------------------------------------------------

# Anthropic / Claude direct (leave blank to use Claude subscription)
ANTHROPIC_API_KEY=""

# Alibaba Coding Plan — used by use-alibaba() in .zshrc
# Also reused as OPENAI_API_KEY for Goose DashScope backend
ALIBABA_API_KEY=""
OPENAI_API_KEY=""          # set same as ALIBABA_API_KEY if using DashScope

# Apple In-App Purchase (App Store Connect)
IAP_APPLE_KEY_ID=""
IAP_APPLE_ISSUER_ID=""
# Note: IAP_APPLE_PRIVATE_KEY_PATH is a local file path — not a secret itself,
# but the .p8 file it points to must never be committed.
IAP_APPLE_PRIVATE_KEY_PATH=""

# ------------------------------------------------------------
# MCP SERVERS (opencode, cursor, antigravity)
# ------------------------------------------------------------

# Supabase — used by opencode mcp.json
MCPSERVERS_SUPABASE_ENV_SUPABASE_ACCESS_TOKEN=""

# Figma — used by opencode mcp.json
FIGMA_API_KEY=""

# n8n — used by cursor mcp.json (if configured)
N8N_API_KEY=""
N8N_BASE_URL=""

# ------------------------------------------------------------
# AI PROVIDER KEYS
# ------------------------------------------------------------

# OpenAI (direct, not DashScope)
OPENAI_DIRECT_API_KEY=""

# Anthropic (redundant with above — some tools use this name)
ANTHROPIC_DIRECT_API_KEY=""

# Gemini / Google AI
GEMINI_API_KEY=""

# Ollama (local — usually no key needed, just host)
OLLAMA_HOST="http://localhost:11434"

# LM Studio (local — usually no key needed)
# LM_STUDIO_BASE_URL="http://localhost:1234"

# ------------------------------------------------------------
# GIT IDENTITY (rendered into ~/.gitconfig.local)
# ------------------------------------------------------------
GIT_USER_NAME=""
GIT_USER_EMAIL=""
